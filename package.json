{
  "name": "aurion-editor",
  "version": "1.0.0",
  "description": "Admin panel with visual HTML editor for static sites",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "staticflow": "./bin/staticflow.js"
  },
  "scripts": {
    "dev": "node server/server.js",
    "dev:admin": "cd admin && ./node_modules/.bin/vite",
    "dev:full": "node server/server.js & cd admin && ./node_modules/.bin/vite --port 5173",
    "build:admin": "cd admin && npm install && ./node_modules/.bin/tsc -b && ./node_modules/.bin/vite build",
    "build:site": "node build.js build",
    "build": "npm run build:admin && npm run build:site",
    "start": "NODE_ENV=production node server/server.js",
    "server": "node server/server.js",
    "clean": "node build.js clean",
    "test": "node --test tests/**/*.test.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.0",
    "better-sqlite3": "^11.8.1",
    "cheerio": "^1.2.0",
    "chokidar": "^3.6.0",
    "clean-css": "^5.3.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "glob": "^10.4.5",
    "html-minifier-terser": "^7.2.0",
    "puppeteer": "^24.39.0",
    "sharp": "^0.33.5",
    "terser": "^5.36.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0"
  }
}
